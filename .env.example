# Local TV Time Environment Variables

# 1. Your TMDB API Keys (Get these from https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_ACCESS_TOKEN=your_tmdb_read_access_token_here

# 2. Security (Generate a random secure string for your JWT tokens)
JWT_SECRET=generate-a-long-random-string-here

# 3. Push Notifications (Generate using web-push or a VAPID generator)
# E.g. npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# 4. Optional: Tailscale VPN Integration (if deploying with docker-compose.tailscale.yml)
# Generate an Auth Key at https://login.tailscale.com/admin/settings/keys
# TS_AUTHKEY=your_tailscale_auth_key_here

